<rml>
  <head>
    <title>WORR Callvote Unlagged</title>
    <link type="text/rcss" href="../common/theme/base.rcss" />
    <link type="text/rcss" href="../common/theme/session.rcss" />
    <link type="text/rcss" href="../common/theme/accessibility.rcss" />
  </head>
  <body id="session-callvote-unlagged" data-route-id="callvote_unlagged" data-route-group="session" data-route-version="1" data-document-status="round3-scaffold" data-owner="agent5" data-session-owner="sgame">
    <div class="screen compact-screen session-screen" id="callvote-unlagged-screen">
      <header class="page-header">
        <h1>Callvote: Unlagged</h1>
        <p id="callvote-unlagged-current" class="status-message" data-bind="cvars.ui_callvote_unlagged_current" data-visible-if="ui_callvote_unlagged_current">Current unlagged state</p>
      </header>

      <nav class="menu-list" id="callvote-unlagged-menu" data-model="session.callvote.unlagged" data-owner-boundary="sgame-published-cvars">
        <button id="callvote-unlagged-enable" type="button" data-command="worr_callvote_unlagged 1">Enable</button>
        <button id="callvote-unlagged-disable" type="button" data-command="worr_callvote_unlagged 0">Disable</button>
      </nav>

      <footer class="actions" id="callvote-unlagged-actions">
        <button id="callvote-unlagged-return" type="button" data-command="popmenu">Return</button>
      </footer>
    </div>
  </body>
</rml>
