	border-color: #ffffff;
}

.ui-high-visibility .match-hub-context,
.ui-high-visibility .match-hub-eyebrow,
.ui-high-visibility .match-hub-tools-label,
.ui-high-visibility .match-hub-gametype,
.ui-high-visibility .match-hub-stat-label
{
	color: #ffff00;
}

.ui-high-visibility .match-hub-state,
.ui-high-visibility .match-hub-tab,
.ui-high-visibility .match-hub-join-actions .match-hub-join-button,
.ui-high-visibility .match-hub-tools button,
.ui-high-visibility .match-hub-footer-actions button
{
	background-color: #000000;
	color: #ffffff;
	border-color: #ffffff;
	decorator: none;
}

.ui-high-visibility .match-hub-tab.is-active
{
	background-color: #202000;
	color: #ffff00;
	border-bottom-color: #ffff00;
}

.ui-high-visibility button.match-hub-tab:hover,
.ui-high-visibility button.match-hub-tab:focus,
.ui-high-visibility .match-hub-join-actions .match-hub-join-button:hover,
.ui-high-visibility .match-hub-join-actions .match-hub-join-button:focus,
.ui-high-visibility .match-hub-tools button:hover,
.ui-high-visibility .match-hub-tools button:focus,
.ui-high-visibility .match-hub-footer-actions button:hover,
.ui-high-visibility .match-hub-footer-actions button:focus
{
	background-color: #202000;
	color: #ffff00;
	border-color: #ffff00;
	decorator: none;
}

#callvote-main-menu button:hover,
#callvote-main-menu button:focus,
#callvote-random-menu button:hover,
#callvote-random-menu button:focus,
#callvote-scorelimit-menu button:hover,
#callvote-scorelimit-menu button:focus,
#callvote-timelimit-menu button:hover,
#callvote-timelimit-menu button:focus,
#callvote-unlagged-menu button:hover,
#callvote-unlagged-menu button:focus,
#callvote-ruleset-menu button:hover,
#callvote-ruleset-menu button:focus,
#callvote-map-flags-content button:hover,
#callvote-map-flags-content button:focus,
#mymap-flags-content button:hover,
#mymap-flags-content button:focus,
#map-selector-options button:hover,
#map-selector-options button:focus
{
	background-color: #30291f;
	border-color: #b99b5b;
	border-left-color: #ffd967;
}

.menu-list button,
.session-command-list button
{
	width: 100%;
	text-align: left;
	margin-bottom: 6px;
	transition: background-color border-color color padding-left 0.12s cubic-out;
}

.menu-list button:hover,
.session-command-list button:hover
{
	padding-left: 16px;
}

.session-command-strip
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	margin-bottom: 8px;
}

.session-flow
{
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	min-height: 0px;
	overflow: auto;
}

.session-flow-step
{
	display: flex;
	flex-direction: column;
	padding: 12px;
	background-color: #27231d;
	border-left-width: 4px;
	border-left-color: #756a5d;
	border-radius: 3px;
	margin-bottom: 8px;
	transition: background-color border-color color 0.12s cubic-out;
}

.session-flow-step:hover
{
	background-color: #30291f;
	border-left-color: #b99b5b;
}

.session-flow-step.is-active
{
	background-color: #332d23;
	border-left-color: #ffd967;
}

.session-flow-step.is-complete
{
	border-left-color: #83d18f;
}

.session-flow-step.is-blocked,
.session-flow-step.is-danger
{
	border-left-color: #ee6758;
}

.vote-status,
.session-stat-grid
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	margin: 0px;
	padding: 12px;
	background-color: #1b1916;
	border-width: 2px;
	border-color: #756a5d;
	border-radius: 3px;
	margin-bottom: 12px;
}

.vote-status dt,
.session-stat-grid dt,
.session-stat-label
{
	width: 160px;
	margin: 0px;
	color: #c9beb0;
	font-weight: bold;
	white-space: normal;
	word-break: break-word;
}

.vote-status dd,
.session-stat-grid dd,
.session-stat-value
{
	flex: 1 1 220px;
	margin: 0px;
	color: #f3eee4;
	white-space: normal;
	word-break: break-word;
}

.vote-status .is-winning,
.session-stat-value.is-winning
{
	color: #83d18f;
}

.vote-status .is-losing,
.session-stat-value.is-losing
{
	color: #ee6758;
}

.session-vote-prompt,
.session-match-summary,
.session-admin-summary
{
	display: flex;
	flex-direction: column;
	min-height: 0px;
	overflow: auto;
	padding: 16px;
	background-color: #27231d;
	border-width: 2px;
	border-color: #b99b5b;
	border-radius: 6px;
	margin-bottom: 12px;
}

.session-vote-prompt h2,
.session-match-summary h2,
.session-admin-summary h2
{
	margin-bottom: 0px;
}

.session-countdown
{
	display: inline-block;
	min-width: 64px;
	padding: 4px 8px;
	background-color: #000000;
	color: #ffd967;
	border-width: 2px;
	border-color: #b99b5b;
	border-radius: 3px;
	text-align: center;
	font-family: "WORR Mono";
}

.session-player-list,
.session-admin-list
{
	display: flex;
	flex-direction: column;
	min-height: 0px;
	overflow: auto;
}

.session-player-row,
.session-admin-row
{
	display: flex;
	flex-direction: row;
	align-items: center;
	flex: 0 0 auto;
	min-height: 36px;
	padding: 8px;
	background-color: #1b1916;
	border-width: 1px;
	border-color: #756a5d;
	border-radius: 3px;
	margin-bottom: 4px;
	transition: background-color border-color color 0.12s cubic-out;
}

.session-player-row:hover,
.session-admin-row:hover
{
	background-color: #211e19;
	border-color: #b99b5b;
}

.session-player-row.is-selected,
.session-admin-row.is-selected
{
	background-color: #332d23;
	border-color: #ffd967;
	color: #ffd967;
}

.session-player-name,
.session-admin-label
{
	flex: 1 1 auto;
	min-width: 0px;
	white-space: normal;
	word-break: break-word;
}

#admin-commands-screen .page-header
{
	margin-bottom: 8px;
}

#admin-commands-screen .page-header h1
{
	margin-bottom: 2px;
}

#admin-commands-list
{
	flex: 1 1 auto;
	width: 632px;
	min-width: 0px;
	max-width: 100%;
	height: auto;
	min-height: 0px;
	padding-right: 6px;
	margin-bottom: 8px;
	overflow: auto;
}

#admin-commands-list .session-admin-row
{
	align-items: flex-start;
	flex-wrap: wrap;
	width: 584px;
	min-height: 44px;
	padding: 7px 9px;
}

#admin-commands-list .session-admin-row span
{
	display: block;
	flex: 0 0 auto;
	width: 394px;
	white-space: normal;
	word-break: break-word;
}

#admin-commands-list .session-admin-row .session-admin-label
{
	width: 132px;
	margin-right: 14px;
	color: #ffd967;
	font-family: "WORR Mono";
	font-size: 14px;
}

#admin-commands-list .session-admin-row .ui-command-line
{
	width: 394px;
	margin-left: 146px;
	margin-top: 3px;
	font-size: 12px;
	color: #c9beb0;
	white-space: normal;
	word-break: break-word;
}

#admin-menu-actions,
#map-selector-options,
#match-stats-lines,
#tourney-mapchoices-list,
#dm-hostinfo-content,
#dm-matchinfo-content,
#dm-welcome-content
{
	flex: 1 1 auto;
	min-height: 0px;
	overflow: auto;
}

#mymap-main-content
{
	flex: 0 0 auto;
	width: 620px;
	min-width: 0px;
	max-width: 100%;
	min-height: 0px;
}

#admin-menu-actions
{
	flex: 0 0 auto;
	width: 604px;
	max-width: 100%;
}

#match-stats-lines,
#tourney-mapchoices-list
{
	flex: 0 1 auto;
}

#map-selector-options
{
	padding-right: 6px;
}

#map-selector-options button
{
	min-height: 54px;
	margin-bottom: 8px;
	padding: 10px 12px;
	border-left-width: 4px;
	border-left-color: #4b4235;
	text-align: left;
}

#map-selector-status .status-panel
{
	padding: 12px;
	margin-bottom: 8px;
}

#map-selector-bar
{
	padding: 6px 8px;
	background-color: #14120f;
	border-width: 1px;
	border-color: #443d33;
	border-radius: 3px;
	color: #ffd967;
}

#tourney-veto-content
{
	width: 620px;
	max-width: 100%;
}

#tourney-veto-inactive-panel
{
	min-height: 74px;
}

#tourney-veto-ban-locked
{
	min-width: 100px;
	white-space: nowrap;
}

#tourney-veto-state p
{
	flex: 1 1 240px;
	min-width: 0px;
	margin: 0px;
	color: #f3eee4;
	white-space: normal;
	word-break: break-word;
}

#tourney-veto-state p:first-child
{
	margin-right: 16px;
}

#match-stats-lines,
#tourney-mapchoices-list
{
	width: auto;
	min-width: 0px;
	max-width: 100%;
	padding: 10px;
	background-color: #171511;
	border-left-width: 3px;
	border-left-color: #4b4235;
}

.session-static-report
{
	display: flex;
	flex-direction: column;
	width: 100%;
	min-height: 0px;
}

#match-stats-lines p,
#tourney-mapchoices-list p
{
	width: auto;
	max-width: 100%;
	min-width: 0px;
	padding: 5px 8px;
	background-color: #211e19;
	border-left-width: 1px;
	border-left-color: #332d23;
	border-radius: 3px;
	margin-bottom: 4px;
	font-size: 15px;
	line-height: 1.1;
	white-space: normal;
	word-break: break-word;
}

#match-stats-line-0,
#tourney-mapchoice-line-0,
#match-stats-fallback-title,
#tourney-mapchoices-fallback-0
{
	border-left-width: 4px;
	border-left-color: #b99b5b;
	color: #ffd967;
	font-weight: bold;
}

.session-match-stats-content
{
	flex: 0 1 auto;
	width: 620px;
	max-width: 100%;
	min-width: 0px;
}

.match-stats-player
{
	width: auto;
	min-width: 0px;
	padding: 12px 14px;
	margin-bottom: 10px;
	background-color: #171511;
	border-left-width: 4px;
	border-left-color: #b99b5b;
	border-radius: 3px;
}

.match-stats-player span
{
	display: block;
	margin-bottom: 3px;
	color: #c9beb0;
	font-size: 13px;
	text-transform: uppercase;
	letter-spacing: 1px;
}

.match-stats-player h2
{
	margin: 0px;
	color: #ffd967;
	font-size: 22px;
}

.match-stats-grid
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	width: 100%;
	min-width: 0px;
}

.match-stats-card
{
	flex: 1 1 188px;
	min-width: 176px;
	padding: 10px;
	margin-right: 8px;
	margin-bottom: 8px;
	background-color: #211e19;
	border-width: 1px;
	border-color: #574d3e;
	border-radius: 4px;
}

#match-stats-accuracy-card
{
	margin-right: 0px;
}

.match-stats-card h2
{
	margin: 0px 0px 8px 0px;
	padding-bottom: 6px;
	border-bottom-width: 1px;
	border-bottom-color: #4b4235;
	color: #ffd967;
	font-size: 17px;
}

.match-stats-row
{
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	width: 100%;
	min-width: 0px;
	padding: 5px 0px;
}

.match-stats-row span
{
	flex: 1 1 auto;
	min-width: 0px;
	color: #c9beb0;
	font-size: 13px;
}

.match-stats-row strong
{
	flex: 0 0 auto;
	margin-left: 8px;
	color: #f3eee4;
	font-family: "WORR Mono";
	font-size: 14px;
	text-align: right;
}

.session-badge
{
	display: inline-block;
	min-width: 72px;
	padding: 4px 8px;
	background-color: #27231d;
	color: #c9beb0;
	border-width: 1px;
	border-color: #756a5d;
	border-radius: 3px;
	text-align: center;
}

.session-badge.is-live
{
	color: #83d18f;
	border-color: #83d18f;
}

.session-badge.is-warning
{
	color: #ffd967;
	border-color: #ffd967;
}

.session-badge.is-danger
{
	color: #ee6758;
	border-color: #ee6758;
}

.session-admin-actions
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	margin-top: 8px;
}

.session-pending
{
	color: #c9beb0;
	font-style: italic;
}

.session-error
{
	color: #ee6758;
}

.actions
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
}

.ui-high-visibility .session-panel,
.ui-high-visibility .status-panel,
.ui-high-visibility .session-card,
.ui-high-visibility .vote-status,
.ui-high-visibility .session-stat-grid,
.ui-high-visibility .session-vote-prompt,
.ui-high-visibility .session-match-summary,
.ui-high-visibility .session-admin-summary,
.ui-high-visibility .session-info-row,
.ui-high-visibility .session-info-line,
.ui-high-visibility .session-player-row,
.ui-high-visibility .session-admin-row
{
	background-color: #000000;
	border-color: #ffffff;
	color: #ffffff;
}

.ui-high-visibility .session-flow-step.is-active,
.ui-high-visibility .session-player-row.is-selected,
.ui-high-visibility .session-admin-row.is-selected
{
	background-color: #202000;
	border-color: #ffd967;
	color: #ffd967;
}

#leave-match-yes,
#forfeit-confirm-yes
{
	background-color: #281b18;
	border-color: #895047;
	border-left-width: 4px;
	border-left-color: #ee6758;
}

#leave-match-yes:hover,
#forfeit-confirm-yes:hover
{
	background-color: #321f1b;
	border-color: #ee6758;
	border-left-color: #ff9285;
	color: #ee6758;
}

#leave-match-yes:focus,
#forfeit-confirm-yes:focus
{
	background-color: #321f1b;
	border-color: #ffd967;
	border-left-color: #ff9285;
	color: #ee6758;
}

#leave-match-yes:active,
#forfeit-confirm-yes:active
{
	background-color: #402420;
	border-color: #ff9285;
	border-left-color: #ff9285;
	color: #ff9285;
}

/*
 * Pressed feedback: family-scoped rules above out-specify base button:active,
 * so list, hub, and tool buttons declare their own.
 */
#callvote-main-menu button:active,
.menu-list button:active,
.session-command-list button:active,
#map-selector-options button:active
{
	background-color: #3f3626;
	border-color: #ffd967;
	border-left-color: #ffd967;
	color: #ffd967;
}

button.match-hub-tab:active
{
	background-color: #3f2b1a;
	color: #ffe1b8;
	border-bottom-color: #ffd967;
	decorator: none;
}

.match-hub-join-actions .match-hub-join-button:active
{
	background-color: #4a3524;
	color: #fff1df;
	border-color: #ffd967;
	decorator: none;
}

.match-hub-tools button:active
{
	background-color: #42301d;
	color: #ffe1b8;
	border-color: #ffd967;
	decorator: none;
}

/*
 * FR-09-T12 multiplayer hub revision.
 *
 * The join hub is a compact in-world instrument panel: the primary route rail
 * is persistent, unavailable destinations remain visible, focus is distinct
 * from selection, and a live vote can replace the overview without moving the
 * participation controls.
 */
.match-hub-shell
{
	width: 856px;
	height: 600px;
	background-color: #0d0b09ed;
	border-color: #67503b;
	border-left-width: 1px;
	border-top-width: 2px;
	border-top-color: #b4632a;
}

.match-hub-header
{
	min-height: 80px;
	padding: 6px 12px;
	background-color: #120e0bea;
	border-bottom-width: 1px;
	border-bottom-color: #624027;
}

.match-hub-brand
{
	width: 132px;
	height: 74px;
	margin-right: 14px;
	background-color: transparent;
	border-right-width: 1px;
	border-right-color: #493326;
}

.match-hub-logo
{
	width: 96px;
	height: 72px;
	margin-left: 4px;
}

.match-hub-heading h1
{
	font-size: 25px;
	letter-spacing: 1px;
}

.match-hub-context
{
	font-size: 10px;
	letter-spacing: 2px;
}

.match-hub-subtitle
{
	font-size: 13px;
}

.match-hub-meta
{
	display: flex;
	flex-direction: column;
	align-items: stretch;
	justify-content: center;
	flex: 0 0 auto;
	width: 174px;
	margin-left: 12px;
}

.match-hub-state
{
	display: flex;
	flex-direction: column;
	box-sizing: border-box;
	width: 100%;
	min-width: 0px;
	max-width: none;
	padding: 6px 9px;
	margin: 0px;
	background-color: #201812d9;
	border-width: 1px;
	border-color: #63452f;
	border-left-width: 3px;
	border-left-color: #ed842e;
	border-radius: 2px;
	text-align: left;
}

.match-hub-state-label
{
	display: block;
	margin-bottom: 2px;
	color: #967e68;
	font-family: "WORR Display";
	font-size: 9px;
	font-weight: bold;
	letter-spacing: 1px;
	text-transform: uppercase;
}

.match-hub-state-line
{
	display: flex;
	flex-direction: row;
	align-items: center;
	min-width: 0px;
}

.match-hub-state-line strong
{
	display: block;
	min-width: 0px;
	color: #ffd3a0;
	font-family: "WORR Mono";
	font-size: 11px;
	font-weight: bold;
	text-transform: uppercase;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.match-hub-state-signal
{
	display: block;
	flex: 0 0 auto;
	width: 7px;
	height: 7px;
	margin-right: 7px;
	background-color: #ed842e;
	border-width: 1px;
	border-color: #ffc176;
	border-radius: 5px;
}

.match-hub-clock
{
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: flex-end;
	margin-top: 4px;
	color: #88796b;
	font-family: "WORR Mono";
	font-size: 9px;
	white-space: nowrap;
}

.match-hub-clock-time
{
	display: block;
	margin-right: 8px;
	color: #cbb6a2;
	font-size: 10px;
	font-weight: bold;
}

.match-hub-clock-date
{
	display: block;
}

.match-hub-tabs
{
	align-items: stretch;
	min-height: 36px;
	padding: 0px 14px;
	background-color: #090807ef;
	border-bottom-color: #60432e;
}

.match-hub-tab,
button.match-hub-tab
{
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	flex: 1 1 0px;
	width: auto;
	min-width: 0px;
	max-width: none;
	min-height: 36px;
	padding: 4px 8px 2px 8px;
	background-color: transparent;
	color: #a99786;
	border-width: 0px;
	border-right-width: 0px;
	border-bottom-width: 3px;
	border-bottom-color: #231a14;
	font-size: 12px;
	font-weight: normal;
	letter-spacing: 1px;
	text-transform: uppercase;
}

.match-hub-tab-indicator
{
	display: block;
	flex: 0 0 auto;
	width: 5px;
	height: 5px;
	margin-right: 7px;
	background-color: #4f4034;
	border-radius: 3px;
}

.match-hub-tab.is-active
{
	background-color: #1b140fcc;
	color: #fff1df;
	border-bottom-color: #ed842e;
	font-weight: bold;
	tab-index: auto;
}

.match-hub-tab.is-active .match-hub-tab-indicator
{
	background-color: #ed842e;
	border-width: 1px;
	border-color: #ffbd72;
}

button.match-hub-tab:hover
{
	background-color: #1d1712b8;
	color: #e7c39f;
	border-bottom-color: #755039;
}

button.match-hub-tab:focus
{
	background-color: #17120ee0;
	color: #ffd967;
	border-width: 1px;
	border-color: #ffd967;
	border-bottom-width: 3px;
	border-bottom-color: #80603d;
}

button.match-hub-tab.is-active:focus
{
	background-color: #1b140fcc;
	color: #fff1df;
	border-width: 1px;
	border-color: #ffd967;
	border-bottom-width: 3px;
	border-bottom-color: #ed842e;
}

button.match-hub-tab:disabled,
button.match-hub-tab[disabled]
{
	background-color: transparent;
	color: #5f574f;
	border-width: 0px;
	border-bottom-width: 3px;
	border-bottom-color: #1b1714;
	opacity: 0.55;
}

button.match-hub-tab:disabled .match-hub-tab-indicator,
button.match-hub-tab[disabled] .match-hub-tab-indicator
{
	background-color: #302b27;
	border-width: 1px;
	border-color: #514b45;
}

.match-hub-content
{
	padding: 10px;
	background-color: #0b0908c7;
}

.match-hub-overview,
.match-hub-active-vote,
.match-hub-participation
{
	box-sizing: border-box;
	min-width: 0px;
	min-height: 0px;
	padding: 11px;
	background-color: #15110ee8;
	border-width: 1px;
	border-color: #48382c;
	border-top-width: 2px;
	border-top-color: #765033;
	border-radius: 2px;
}

.match-hub-overview,
.match-hub-active-vote
{
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	overflow: hidden;
}

.match-hub-participation
{
	width: 264px;
	margin-left: 10px;
	background-color: #18110de8;
	border-top-color: #d3742c;
	overflow: hidden;
}

.match-hub-section-heading
{
	margin-bottom: 6px;
}

.match-hub-section-heading h2
{
	font-size: 17px;
}

.match-hub-map-card
{
	display: flex;
	flex-direction: row;
	align-items: center;
	min-height: 74px;
	padding: 8px 10px;
	margin-bottom: 7px;
	background-color: #0a0807dc;
	border-left-width: 3px;
}

.match-hub-map-copy
{
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	min-width: 0px;
}

.match-hub-map
{
	font-size: 21px;
}

.match-hub-limits
{
	display: flex;
	flex-direction: column;
	justify-content: center;
	flex: 0 0 auto;
	box-sizing: border-box;
	width: 154px;
	min-height: 50px;
	padding-left: 12px;
	margin-left: 12px;
	border-left-width: 1px;
	border-left-color: #503929;
}

.match-hub-limits span
{
	display: block;
	margin: 2px 0px;
	color: #b9a38e;
	font-family: "WORR Mono";
	font-size: 10px;
	text-align: right;
	white-space: normal;
}

.match-hub-stat-grid
{
	margin-right: -5px;
	margin-bottom: 1px;
}

.match-hub-stat
{
	flex: 1 1 128px;
	min-width: 128px;
	min-height: 38px;
	padding: 6px 7px;
	margin-right: 5px;
	margin-bottom: 5px;
	background-color: #1d1712cc;
	border-left-width: 2px;
}

.match-hub-stat-label
{
	width: auto;
	margin-right: 6px;
	font-size: 9px;
	letter-spacing: 1px;
}

.match-hub-stat-value
{
	font-size: 10px;
}

.match-hub-stat-wide
{
	flex: 1 1 100%;
	border-left-color: #b66731;
}

.match-hub-motd
{
	padding: 6px 8px;
}

.match-hub-context-actions
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	align-items: center;
	flex: 0 0 auto;
	min-height: 0px;
	margin-top: auto;
	padding-top: 8px;
}

.match-hub-context-actions button
{
	width: auto;
	min-width: 92px;
	min-height: 26px;
	padding: 3px 8px;
	margin: 0px 5px 0px 0px;
	background-color: #19140f;
	color: #aa9785;
	border-width: 1px;
	border-color: #49382a;
	border-radius: 2px;
	decorator: none;
	font-size: 10px;
}

.match-hub-context-actions button:hover,
.match-hub-context-actions button:focus
{
	background-color: #2a1d14;
	color: #ffd4a1;
	border-color: #b86c34;
	decorator: none;
}

.match-hub-active-vote
{
	justify-content: center;
	background-color: #15100ded;
	border-top-color: #e38838;
}

.match-hub-vote-heading
{
	display: flex;
	flex-direction: row;
	align-items: flex-start;
	justify-content: space-between;
	margin-bottom: 16px;
}

.match-hub-vote-heading h2
{
	margin: 0px;
	font-size: 23px;
}

.match-hub-live-badge
{
	display: flex;
	flex-direction: row;
	align-items: center;
	padding: 4px 8px;
	background-color: #2b1712;
	color: #ffad66;
	border-width: 1px;
	border-color: #864a29;
	border-radius: 10px;
	font-family: "WORR Mono";
	font-size: 9px;
	font-weight: bold;
	letter-spacing: 1px;
	text-transform: uppercase;
}

.match-hub-live-badge > span:first-child
{
	display: block;
	width: 6px;
	height: 6px;
	margin-right: 5px;
	background-color: #ff6c45;
	border-radius: 3px;
}

.match-hub-vote-caller
{
	margin: 0px 0px 7px 0px;
	color: #9f8e7d;
	font-size: 11px;
}

.match-hub-vote-caller strong
{
	color: #e5c3a3;
	font-weight: bold;
}

.match-hub-vote-caller span
{
	margin-left: 4px;
}

.match-hub-vote-proposal
{
	display: flex;
	align-items: center;
	box-sizing: border-box;
	min-height: 94px;
	padding: 16px;
	background-color: #090706df;
	color: #fff1df;
	border-width: 1px;
	border-color: #6a4931;
	border-left-width: 4px;
	border-left-color: #ed842e;
	font-family: "WORR Display";
	font-size: 20px;
	white-space: normal;
	word-break: break-word;
}

.match-hub-vote-proposal > span
{
	display: block;
	width: 100%;
}

.match-hub-vote-status
{
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	padding: 8px 2px;
	color: #b6a18d;
	font-size: 11px;
}

.match-hub-vote-timer
{
	display: flex;
	flex-direction: row;
	align-items: baseline;
	color: #9d8b7b;
	font-family: "WORR Mono";
	font-size: 9px;
	text-transform: uppercase;
}

.match-hub-vote-timer strong
{
	margin-right: 4px;
	color: #ffbd72;
	font-size: 18px;
}

.match-hub-vote-actions
{
	display: flex;
	flex-direction: row;
	align-items: stretch;
	margin-top: 4px;
}

.match-hub-vote-actions button
{
	flex: 1 1 0px;
	width: auto;
	min-width: 0px;
	min-height: 42px;
	margin: 0px 6px 0px 0px;
	background-color: #202018;
	border-width: 1px;
	border-color: #65543f;
	border-left-width: 4px;
	decorator: none;
	font-size: 15px;
}

.match-hub-vote-actions .vote-yes
{
	background-color: #162319;
	border-left-color: #6cb979;
}

.match-hub-vote-actions .vote-no
{
	margin-right: 0px;
	background-color: #2a1715;
	border-left-color: #d35f50;
}

.match-hub-vote-actions button:hover,
.match-hub-vote-actions button:focus
{
	background-color: #34271b;
	color: #ffd967;
	border-color: #ffd967;
	decorator: none;
}

.match-hub-vote-actions button:disabled,
.match-hub-vote-actions button[disabled]
{
	background-color: #151310;
	color: #625a53;
	border-color: #413a33;
	border-left-color: #4c443c;
}

.match-hub-footer
{
	min-height: 48px;
	padding: 6px 10px;
	background-color: #100d0bec;
	border-top-width: 1px;
	border-top-color: #563923;
}

.match-hub-tooltip
{
	display: block;
	flex: 1 1 auto;
	min-width: 0px;
	margin: 0px;
	color: #9d8d7e;
	font-size: 10px;
	line-height: 1.2;
	white-space: normal;
	word-break: break-word;
}

.match-hub-tooltip.is-active
{
	color: #e4bd96;
}

.match-hub-footer-actions
{
	display: flex;
	flex-direction: row;
	flex: 0 1 326px;
	width: 326px;
	min-width: 0px;
	margin-left: 10px;
}

.match-hub-footer-actions button
{
	flex: 0 0 auto;
	width: auto;
	min-width: 72px;
	min-height: 32px;
	padding: 4px 9px;
	margin-left: 6px;
	font-size: 11px;
}

.match-hub-footer-actions .match-hub-leave
{
	min-width: 120px;
}

.match-hub-join-actions
{
	justify-content: center;
	flex: 1 1 auto;
}

.match-hub-settings,
.match-hub-forfeit
{
	background-color: #191510;
	border-color: #59412f;
}

.match-hub-forfeit
{
	color: #dc958a;
	border-left-width: 3px;
	border-left-color: #b84c43;
}

@media (max-width: 760px)
{
	.match-hub-brand
	{
		width: 104px;
		height: 62px;
	}

	.match-hub-logo
	{
		width: 92px;
		height: 62px;
	}

	.match-hub-meta
	{
		width: 142px;
	}

	.match-hub-tabs
	{
		flex-wrap: wrap;
	}

	.match-hub-tab,
	button.match-hub-tab
	{
		flex: 1 1 118px;
		min-height: 32px;
	}

	.match-hub-content
	{
		flex-direction: column;
		overflow: auto;
	}

	.match-hub-overview,
	.match-hub-active-vote,
	.match-hub-participation
	{
		flex: 0 0 auto;
		width: auto;
		overflow: visible;
	}

	.match-hub-participation
	{
		margin-left: 0px;
		margin-top: 8px;
	}
}
