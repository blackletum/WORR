/*
 * WORR RmlUi session-page theme contract.
 *
 * Import after common/theme/base.rcss. These rules cover live and staged vote,
 * match, information, and admin flows across the shared native data bridge.
 */

.session-screen,
#vote-menu-screen,
#multiplayer-screen
{
	display: flex;
	flex-direction: column;
	min-height: 0px;
}

/*
 * Session pages are in-world interfaces: a low-opacity viewport scrim keeps
 * the surrounding arena readable while the menu itself occupies a centered,
 * translucent metal frame. Popup routes intentionally restore the full-screen
 * scrim so destructive choices remain unmistakable.
 */
body[data-route-group="session"]
{
	background-color: #05030258;
}

.session-screen
{
	top: 32px;
	right: 40px;
	bottom: 32px;
	left: 40px;
	padding: 12px;
	background-color: #100d0be8;
	border-width: 1px;
	border-color: #765538;
	border-left-width: 4px;
	border-left-color: #ed842e;
	border-radius: 4px;
	decorator: ninepatch(popup, popup-inner) border-box;
}

.session-screen.popup-screen,
body.ui-session-overlay .session-screen.popup-screen
{
	top: 0px;
	right: 0px;
	bottom: 0px;
	left: 0px;
	padding: 18px;
	background-color: #080706d8;
	border-width: 0px;
	decorator: none;
}

.session-layout
{
	display: flex;
	flex-direction: row;
	align-items: stretch;
	flex: 1 1 auto;
	min-height: 0px;
	overflow: hidden;
}

.session-main
{
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	min-width: 0px;
	min-height: 0px;
	overflow: auto;
}

.session-side
{
	display: flex;
	flex-direction: column;
	width: 260px;
	min-width: 220px;
	max-width: 300px;
	min-height: 0px;
	margin-left: 16px;
	overflow: auto;
}

.session-panel,
.status-panel,
.session-card
{
	display: flex;
	flex-direction: column;
	padding: 16px;
	background-color: #1b1916;
	border-width: 2px;
	border-color: #756a5d;
	border-radius: 6px;
	margin-bottom: 12px;
	min-height: 0px;
	transition: background-color border-color 0.12s cubic-out;
}

.status-panel p
{
	margin-bottom: 0px;
	color: #c9beb0;
}

.session-info-list
{
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	min-width: 0px;
	min-height: 0px;
	overflow: auto;
}

.session-info-row,
.session-info-line
{
	box-sizing: border-box;
	min-width: 0px;
	min-height: 36px;
	padding: 8px 12px;
	margin: 0px 0px 6px 0px;
	background-color: #181511;
	border-left-width: 3px;
	border-left-color: #6d4b31;
	border-radius: 3px;
	color: #e7ddd1;
}

.session-info-row
{
	display: flex;
	flex-direction: row;
	align-items: center;
}

.session-info-row-tall
{
	min-height: 72px;
	align-items: flex-start;
}

.session-info-label
{
	display: block;
	flex: 0 0 auto;
	width: 160px;
	color: #a99784;
	font-family: "WORR Display";
	font-size: 12px;
	letter-spacing: 1px;
	text-transform: uppercase;
}

.session-info-value
{
	display: block;
	flex: 1 1 auto;
	min-width: 0px;
	margin: 0px;
	color: #fff1df;
	font-size: 15px;
	white-space: normal;
	word-break: break-word;
}

.session-info-line
{
	display: block;
	font-size: 15px;
	white-space: normal;
	word-break: break-word;
}

.session-info-line-primary
{
	color: #ffd4a1;
	border-left-color: #ed842e;
	font-family: "WORR Display";
	font-size: 17px;
}

.menu-list,
.session-command-list
{
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	min-height: 0px;
	max-width: 604px;
	overflow: auto;
}

#multiplayer-session-status
{
	width: 568px;
	max-width: 568px;
}

.session-vote-option-grid
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	align-content: flex-start;
	flex: 1 1 auto;
	width: 632px;
	min-width: 0px;
	min-height: 0px;
	max-width: 100%;
	height: auto;
	max-height: 430px;
	padding-right: 6px;
	margin-bottom: 8px;
	overflow: auto;
}

.session-vote-option-grid button
{
	position: static;
	display: block;
	box-sizing: border-box;
	width: 296px;
	min-width: 296px;
	max-width: 296px;
	height: auto;
	min-height: 36px;
	padding: 5px 10px;
	background-color: #211e19;
	border-left-width: 4px;
	border-left-color: #4b4235;
	border-radius: 5px;
	font-size: 16px;
	text-align: left;
	margin-right: 8px;
	margin-bottom: 6px;
	transition: background-color border-color color padding-left 0.12s cubic-out;
}

.session-vote-option-grid button:hover
{
	padding-left: 16px;
}

.session-vote-option-grid > .session-pending
{
	box-sizing: border-box;
	width: 620px;
	min-width: 0px;
	max-width: 100%;
}

#session-dm-join,
#session-join
{
	background-color: #00000000;
}

.match-hub-screen
{
	top: 0px;
	right: 0px;
	bottom: 0px;
	left: 0px;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	padding: 32px 40px;
	background-color: transparent;
	border-width: 0px;
	/* No screen backdrop/grime: the hub floats translucent over the game. */
	decorator: none;
}

body.ui-session-overlay .match-hub-screen
{
	top: 0px;
	right: 0px;
	bottom: 0px;
	left: 0px;
	padding: 32px 40px;
	background-color: transparent;
	border-width: 0px;
	decorator: none;
}

.match-hub-shell
{
	display: flex;
	flex-direction: column;
	flex: 0 1 auto;
	box-sizing: border-box;
	width: 848px;
	height: 608px;
	max-width: 100%;
	max-height: 100%;
	min-width: 0px;
	min-height: 0px;
	background-color: #100d0bea;
	border-width: 1px;
	border-color: #765538;
	border-left-width: 4px;
	border-left-color: #ed842e;
	border-radius: 4px;
	/* Hollow-center metal frame keeps the in-match translucency. */
	decorator: ninepatch(popup, popup-inner) border-box;
	overflow: hidden;
}

.match-hub-header
{
	display: flex;
	flex-direction: row;
	align-items: center;
	flex: 0 0 auto;
	min-height: 86px;
	padding: 8px 14px;
	background-color: #1b120eea;
	border-bottom-width: 2px;
	border-bottom-color: #a85b27;
}

.match-hub-brand
{
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: flex-start;
	flex: 0 0 auto;
	width: 176px;
	height: 76px;
	margin-right: 14px;
	background-color: #090706a8;
	border-right-width: 1px;
	border-right-color: #624329;
}

.match-hub-logo
{
	display: block;
	width: 62px;
	height: 62px;
	margin-left: 6px;
}

.match-hub-wordmark
{
	display: flex;
	flex-direction: column;
	justify-content: center;
	margin-left: 8px;
}

.match-hub-wordmark span
{
	color: #fff1df;
	font-family: "WORR Display";
	font-size: 22px;
	font-weight: bold;
	letter-spacing: 2px;
}

.match-hub-wordmark small
{
	color: #dc8a47;
	font-family: "WORR Mono";
	font-size: 10px;
	letter-spacing: 1px;
	text-transform: uppercase;
}

.match-hub-heading
{
	display: flex;
	flex-direction: column;
	justify-content: center;
	flex: 1 1 auto;
	min-width: 0px;
}

.match-hub-heading h1
{
	margin: 0px 0px 2px 0px;
	color: #fff5e8;
	font-size: 28px;
	line-height: 1.05;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.match-hub-context,
.match-hub-eyebrow,
.match-hub-tools-label
{
	margin: 0px 0px 3px 0px;
	color: #dc8a47;
	font-family: "WORR Display";
	font-size: 12px;
	font-weight: bold;
	letter-spacing: 1px;
	text-transform: uppercase;
}

.match-hub-subtitle
{
	margin: 0px;
	color: #cdb9a6;
	font-size: 14px;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.match-hub-state
{
	display: block;
	flex: 0 0 auto;
	min-width: 104px;
	max-width: 150px;
	padding: 6px 9px;
	margin: 0px 0px 0px 12px;
	background-color: #2a1c13;
	color: #ffc176;
	border-width: 1px;
	border-color: #b66a32;
	border-left-width: 4px;
	border-left-color: #ed842e;
	border-radius: 2px;
	font-family: "WORR Mono";
	font-size: 12px;
	font-weight: bold;
	text-align: center;
	text-transform: uppercase;
	white-space: normal;
	word-break: break-word;
}

.match-hub-tabs
{
	display: flex;
	flex-direction: row;
	flex-wrap: nowrap;
	align-items: stretch;
	flex: 0 0 auto;
	min-height: 40px;
	padding: 0px 8px;
	background-color: #0b0908e8;
	border-bottom-width: 1px;
	border-bottom-color: #4a3323;
	overflow: hidden;
}

.match-hub-tab,
button.match-hub-tab
{
	position: static;
	display: block;
	flex: 1 1 auto;
	box-sizing: border-box;
	width: auto;
	min-width: 82px;
	max-width: 160px;
	min-height: 40px;
	padding: 11px 10px 5px 10px;
	margin: 0px;
	background-color: #17110de0;
	color: #cdb9a6;
	border-width: 0px;
	border-right-width: 1px;
	border-right-color: #3f2d20;
	border-bottom-width: 3px;
	border-bottom-color: #302219;
	border-radius: 0px;
	decorator: none;
	font-family: "WORR Display";
	font-size: 14px;
	font-weight: bold;
	text-align: center;
	white-space: nowrap;
	overflow: hidden;
}

.match-hub-tab.is-active
{
	background-color: #2b1c12;
	color: #ffd4a1;
	border-bottom-color: #ed842e;
}

button.match-hub-tab:hover
{
	background-color: #2d2017;
	color: #ffbd72;
	border-bottom-color: #b66a32;
	decorator: none;
}

button.match-hub-tab:focus
{
	background-color: #382519;
	color: #ffe1b8;
	border-width: 1px;
	border-color: #ffd967;
	border-bottom-width: 3px;
	border-bottom-color: #ed842e;
	decorator: none;
}

.match-hub-content
{
	display: flex;
	flex-direction: row;
	align-items: stretch;
	flex: 1 1 auto;
	min-width: 0px;
	min-height: 0px;
	padding: 12px;
	background-color: #100d0bcf;
	overflow: hidden;
}

.match-hub-overview,
.match-hub-participation
{
	display: flex;
	flex-direction: column;
	box-sizing: border-box;
	min-width: 0px;
	min-height: 0px;
	padding: 12px;
	background-color: #18130fdf;
	border-width: 1px;
	border-color: #57412f;
	border-top-width: 3px;
	border-top-color: #9d5727;
	border-radius: 3px;
	overflow: auto;
}

.match-hub-overview
{
	flex: 1 1 auto;
}

.match-hub-participation
{
	flex: 0 0 auto;
	width: 278px;
	margin-left: 12px;
	background-color: #1d1510e8;
	border-top-color: #ed842e;
}

.match-hub-section-heading
{
	display: flex;
	flex-direction: column;
	flex: 0 0 auto;
	margin-bottom: 8px;
}

.match-hub-section-heading h2
{
	margin: 0px;
	font-size: 18px;
}

.match-hub-section-copy
{
	margin: 4px 0px 0px 0px;
	color: #bbaa99;
	font-size: 12px;
	line-height: 1.2;
}

.match-hub-map-card
{
	display: flex;
	flex-direction: column;
	flex: 0 0 auto;
	padding: 9px 11px;
	margin-bottom: 8px;
	background-color: #0d0a08d9;
	border-left-width: 4px;
	border-left-color: #ed842e;
	border-bottom-width: 1px;
	border-bottom-color: #4b3525;
}

.match-hub-gametype
{
	margin: 0px 0px 2px 0px;
	color: #dc8a47;
	font-family: "WORR Display";
	font-size: 13px;
	font-weight: bold;
	text-transform: uppercase;
}

.match-hub-map
{
	margin: 0px 0px 2px 0px;
	color: #fff4e6;
	font-size: 22px;
	white-space: normal;
	word-break: break-word;
}

.match-hub-map-code
{
	margin: 0px;
	color: #9f8e7d;
	font-family: "WORR Mono";
	font-size: 12px;
}

.match-hub-stat-grid
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	align-content: flex-start;
	flex: 0 0 auto;
	min-width: 0px;
	margin-right: -6px;
	margin-bottom: 2px;
}

.match-hub-stat
{
	display: flex;
	flex-direction: row;
	align-items: center;
	flex: 1 1 216px;
	box-sizing: border-box;
	min-width: 196px;
	min-height: 38px;
	padding: 6px 8px;
	margin-right: 6px;
	margin-bottom: 6px;
	background-color: #211912d4;
	border-left-width: 2px;
	border-left-color: #6d4b31;
}

.match-hub-stat-wide
{
	flex: 1 1 100%;
}

.match-hub-stat-label
{
	display: block;
	flex: 0 0 auto;
	width: 88px;
	margin: 0px 8px 0px 0px;
	color: #a99887;
	font-family: "WORR Display";
	font-size: 11px;
	font-weight: bold;
	text-transform: uppercase;
	white-space: normal;
}

.match-hub-stat-value
{
	display: block;
	flex: 1 1 auto;
	min-width: 0px;
	color: #f4e8d9;
	font-family: "WORR Mono";
	font-size: 12px;
	text-align: right;
	white-space: normal;
	word-break: break-word;
}

.match-hub-motd
{
	display: flex;
	flex-direction: column;
	flex: 0 0 auto;
	padding: 8px 10px;
	background-color: #0c0a08c7;
	border-width: 1px;
	border-color: #443124;
	border-left-width: 3px;
	border-left-color: #95613a;
}

.match-hub-motd .match-hub-stat-label
{
	width: auto;
	margin: 0px 0px 4px 0px;
}

.match-hub-motd p
{
	margin: 0px;
	color: #cdbdad;
	font-size: 12px;
	line-height: 1.25;
	white-space: normal;
	word-break: break-word;
}

.match-hub-notice
{
	flex: 0 0 auto;
	padding: 7px 9px;
	margin: 0px 0px 8px 0px;
	background-color: #2b2115;
	color: #ffd08b;
	border-width: 1px;
	border-color: #8c6334;
	border-left-width: 4px;
	border-left-color: #ed842e;
	font-size: 12px;
	line-height: 1.2;
	white-space: normal;
	word-break: break-word;
}

.match-hub-join-actions
{
	display: flex;
	flex-direction: column;
	flex: 0 0 auto;
	min-width: 0px;
	min-height: 0px;
	padding: 0px;
	background-color: transparent;
	border-width: 0px;
	overflow: visible;
}

.match-hub-join-actions .match-hub-join-button
{
	box-sizing: border-box;
	width: 100%;
	min-width: 0px;
	min-height: 38px;
	padding: 6px 10px;
	margin: 0px 0px 7px 0px;
	background-color: #2a2119;
	border-width: 1px;
	border-color: #725238;
	border-left-width: 5px;
	border-left-color: #b86c34;
	border-radius: 2px;
	decorator: none;
	font-size: 15px;
	text-align: left;
}

.match-hub-join-actions .team-red
{
	background-color: #2b1715;
	border-color: #713e37;
	border-left-color: #c84e3e;
}

.match-hub-join-actions .team-blue
{
	background-color: #151f2b;
	border-color: #334f70;
	border-left-color: #4c8fd1;
}

.match-hub-join-actions .ready
{
	background-color: #1c281b;
	border-color: #4b714a;
	border-left-color: #83d18f;
}

.match-hub-join-actions .spectate
{
	background-color: #1b1816;
	border-left-color: #8f8173;
}

.match-hub-join-actions .match-hub-join-button:hover,
.match-hub-join-actions .match-hub-join-button:focus
{
	background-color: #3b2b1e;
	color: #ffe1b8;
	border-color: #ffd967;
	border-left-color: #ed842e;
	decorator: none;
}

.match-hub-join-actions .match-hub-join-button:disabled,
.match-hub-join-actions .match-hub-join-button[disabled]
{
	background-color: #171411;
	color: #756c63;
	border-color: #4a4036;
	border-left-color: #5d5044;
	decorator: none;
}

.match-hub-tools
{
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	align-items: center;
	flex: 0 0 auto;
	min-height: 46px;
	padding: 7px 12px 2px 12px;
	background-color: #0d0a08e8;
	border-top-width: 1px;
	border-top-color: #4b3424;
	border-bottom-width: 1px;
	border-bottom-color: #4b3424;
}

.match-hub-tools-label
{
	flex: 0 0 auto;
	margin: 0px 12px 5px 0px;
}

.match-hub-tools button
{
	width: auto;
	min-width: 88px;
	min-height: 30px;
	padding: 4px 9px;
	margin: 0px 6px 5px 0px;
	background-color: #211912;
	border-width: 1px;
	border-color: #66482f;
	border-radius: 2px;
	decorator: none;
	font-size: 12px;
}

.match-hub-tools button:hover,
.match-hub-tools button:focus
{
	background-color: #352417;
	color: #ffd29b;
	border-color: #ffd967;
	decorator: none;
}

.match-hub-tools button.is-danger
{
	background-color: #281714;
	color: #eaa398;
	border-color: #754139;
	border-left-width: 3px;
	border-left-color: #ee6758;
}

.match-hub-footer
{
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: flex-end;
	flex: 0 0 auto;
	min-height: 48px;
	padding: 7px 12px;
	background-color: #15100deb;
	border-top-width: 2px;
	border-top-color: #704528;
}

.match-hub-instruction
{
	display: block;
	flex: 1 1 auto;
	padding-left: 10px;
	margin: 0px;
	color: #e6c6a4;
	border-left-width: 3px;
	border-left-color: #ed842e;
	font-size: 12px;
	line-height: 1.2;
	white-space: normal;
	word-break: break-word;
}

.match-hub-footer-actions
{
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: flex-end;
	flex: 0 0 auto;
	box-sizing: border-box;
	width: 300px;
	min-width: 300px;
}

.match-hub-footer-actions button
{
	position: static;
	display: block;
	box-sizing: border-box;
	width: auto;
	min-width: 140px;
	min-height: 34px;
	padding: 5px 12px;
	margin: 0px 0px 0px 8px;
	border-radius: 2px;
	decorator: none;
	font-size: 14px;
}

.match-hub-resume
{
	background-color: #2d2116;
	border-color: #a76634;
	border-left-width: 4px;
	border-left-color: #ed842e;
}

.match-hub-leave
{
	background-color: #281714;
	color: #eaa398;
	border-color: #754139;
	border-left-width: 4px;
	border-left-color: #ee6758;
}

.match-hub-footer-actions button:hover,
.match-hub-footer-actions button:focus
{
	background-color: #3b281b;
	color: #ffe1b8;
	border-color: #ffd967;
	decorator: none;
}

@media (max-width: 760px)
{
	.match-hub-shell
	{
		width: 100%;
		height: 100%;
	}

	.match-hub-brand
	{
		width: 132px;
		height: 62px;
		margin-right: 10px;
	}

	.match-hub-logo
	{
		width: 52px;
		height: 52px;
		margin-left: 4px;
	}

	.match-hub-wordmark
	{
		margin-left: 5px;
	}

	.match-hub-wordmark span
	{
		font-size: 17px;
	}

	.match-hub-wordmark small
	{
		font-size: 9px;
	}

	.match-hub-header
	{
		min-height: 70px;
		padding: 6px 10px;
	}

	.match-hub-heading h1
	{
		font-size: 23px;
	}

	.match-hub-state
	{
		min-width: 78px;
		max-width: 108px;
		margin-left: 8px;
	}

	.match-hub-tabs
	{
		flex-wrap: wrap;
	}

	.match-hub-tab,
	button.match-hub-tab
	{
		flex: 1 1 108px;
		max-width: none;
		min-height: 34px;
	}

	.match-hub-content
	{
		flex-direction: column;
		overflow: auto;
	}

	.match-hub-overview,
	.match-hub-participation
	{
		flex: 0 0 auto;
		width: auto;
		overflow: visible;
	}

	.match-hub-participation
	{
		margin-left: 0px;
		margin-top: 10px;
	}
}

@media (max-height: 600px)
{
	.match-hub-screen
	{
		padding: 8px;
	}

	.match-hub-shell
	{
		height: 100%;
	}

	.match-hub-header
	{
		min-height: 68px;
		padding-top: 4px;
		padding-bottom: 4px;
	}

	.match-hub-brand
	{
		height: 58px;
	}

	.match-hub-logo
	{
		width: 50px;
		height: 50px;
	}

	.match-hub-content
	{
		padding: 8px;
	}
}

.ui-high-visibility .match-hub-shell,
.ui-high-visibility .match-hub-header,
.ui-high-visibility .match-hub-tabs,
.ui-high-visibility .match-hub-content,
.ui-high-visibility .match-hub-overview,
.ui-high-visibility .match-hub-participation,
.ui-high-visibility .match-hub-map-card,
.ui-high-visibility .match-hub-stat,
.ui-high-visibility .match-hub-motd,
.ui-high-visibility .match-hub-notice,
.ui-high-visibility .match-hub-tools,
.ui-high-visibility .match-hub-footer
{
	background-color: #000000;
