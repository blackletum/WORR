    {
      "name": "dm_hostinfo",
      "title": "Host Info",
      "style": { "compact": true, "transparent": true },
      "items": [
        { "type": "action", "label": "Server Name:", "align": "left", "selectable": false },
        {
          "type": "wrappedtext",
          "labelCvar": "ui_hostinfo_server",
          "align": "left",
          "maxLines": 3,
          "showIf": ["ui_hostinfo_server"]
        },
        { "type": "blank" },
        { "type": "action", "label": "Host:", "align": "left", "selectable": false, "showIf": ["ui_hostinfo_host"] },
