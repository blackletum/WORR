                "basedir",
                "${workspaceFolder}\\.install",
                "+set",
                "r_renderer",
                "vulkan",
                "+set",
                "logfile",
                "1",
                "+set",
                "logfile_name",
                "vk_q2dm1_launch",
                "+set",
                "developer",
                "1",
                "+set",
                "deathmatch",
                "1",
                "+set",
                "cheats",
                "1",
                "+map",
                "q2dm1"
            ],
            "cwd": "${workspaceFolder}\\.install",
            "console": "integratedTerminal"
        },
        {
            "name": "WORR (RTX)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\.install\\worr_x86_64.exe",
            "args": [
                "+set",
                "basedir",
                "${workspaceFolder}\\.install",
                "+set",
                "r_renderer",
                "rtx",
                "+set",
                "logfile",
                "1",
                "+set",
                "logfile_name",
                "rtx_q2dm1_launch",
                "+set",
                "developer",
                "1",
                "+set",
                "deathmatch",
                "1",
                "+set",
                "cheats",
                "1",
                "+map",
                "q2dm1"
            ],
            "cwd": "${workspaceFolder}\\.install",
