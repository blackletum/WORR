{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "meson: setup",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "if exist builddir-win\\meson-private\\coredata.dat (tools\\meson_setup.cmd setup --native-file meson.native.ini --reconfigure builddir-win -Dbase-game=basew -Ddefault-game=basew -Drmlui=enabled) else (tools\\meson_setup.cmd setup --native-file meson.native.ini builddir-win -Dbase-game=basew -Ddefault-game=basew -Drmlui=enabled)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "meson: compile",
            "type": "shell",
            "command": "meson",
            "args": [
                "compile",
                "-C",
                "builddir-win"
            ],
            "dependsOn": [
                "meson: setup"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "meson: compile (fast)",
            "type": "shell",
            "command": "meson",
            "args": [
                "compile",
                "-C",
                "builddir-win"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "install: refresh (.install)",
            "type": "shell",
            "command": "python",
            "args": [
                "tools/refresh_install.py",
                "--build-dir",
                "builddir-win",
                "--install-dir",
                ".install",
                "--base-game",
                "basew",
                "--platform-id",
                "windows-x86_64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "meson: build",
            "dependsOn": [
                "meson: compile",
                "install: refresh (.install)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "meson: build (fast)",
            "dependsOn": [
                "meson: setup",
                "meson: compile (fast)",
                "install: refresh (.install)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "bot debug: build",
            "dependsOn": [
                "meson: build"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "bot debug: coop campaign matrix smoke",
            "type": "shell",
            "command": "python",
            "args": [
                "tools/bot_scenarios/run_bot_scenarios.py",
                "--scenario",
                "coop_campaign_interaction_matrix",
                "--timeout",
                "120",
                "--base-port",
                "28000",
                "--format",
                "text",
                "--json-out",
                ".tmp/bot_scenarios/vscode_bot_debug_latest.json"
            ],
            "dependsOn": [
                "bot debug: build"
            ],
            "dependsOrder": "sequence",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
